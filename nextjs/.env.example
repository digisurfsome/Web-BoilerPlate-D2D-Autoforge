# =============================================================================
# Environment Variables — Copy this file to .env.local and fill in the values
# =============================================================================

# -- General -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=              # Production URL (e.g. https://yourdomain.com)
# NEXT_PUBLIC_VERCEL_URL is set automatically by Vercel — do not add it here

# -- Supabase ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=          # Supabase project URL (e.g. https://xyz.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # Supabase anon/public key (safe for client)
SUPABASE_SERVICE_ROLE_KEY=         # Supabase service role key (server-only, never expose to client)

# -- Stripe --------------------------------------------------------------------
STRIPE_SECRET_KEY=                 # Stripe secret key (server-only, starts with sk_)
STRIPE_WEBHOOK_SECRET=             # Stripe webhook signing secret (starts with whsec_)

# -- PostHog -------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=           # PostHog project API key
NEXT_PUBLIC_POSTHOG_HOST=          # PostHog instance URL (e.g. https://us.i.posthog.com)
